# ──────────────────────────────────────────────────────────────
# Digital Twin — Environment Variables
# Copy this file to .env and fill in your actual values
# ──────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/digital_twin

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────
# Microsoft OAuth (Azure AD / Entra ID)
# Set up at: https://portal.azure.com → App Registrations
# Required permissions: Calendars.Read, Mail.Read, Mail.Send, User.Read
# ──────────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your_azure_app_client_id
MICROSOFT_CLIENT_SECRET=your_azure_app_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback

# ──────────────────────────────────────────────────────────────
# Zoom OAuth
# Set up at: https://marketplace.zoom.us → Build App → General App
# Required scopes: meeting:read, meeting:write
# ──────────────────────────────────────────────────────────────
ZOOM_CLIENT_ID=your_zoom_app_client_id
ZOOM_CLIENT_SECRET=your_zoom_app_client_secret
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret
ZOOM_REDIRECT_URI=http://localhost:3001/api/auth/zoom/callback

# ──────────────────────────────────────────────────────────────
# Deepgram (Real-time transcription)
# Sign up at: https://deepgram.com (free $200 credit)
# ──────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ──────────────────────────────────────────────────────────────
# Claude API (Anthropic — for meeting summarization)
# Get key at: https://console.anthropic.com
# ──────────────────────────────────────────────────────────────
CLAUDE_API_KEY=your_anthropic_api_key

# Auth secrets (change these in production!)
JWT_SECRET=dev-jwt-secret-change-in-production
SESSION_SECRET=dev-session-secret-change-in-production
